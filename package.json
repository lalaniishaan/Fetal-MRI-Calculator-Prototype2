{
  "name": "fetal-mri-biometry-calculator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --disable-warning=DEP0180 --watch --import ./scripts/register-ts-node.mjs src/server.ts",
    "start": "npm run build && node src/server.js",
    "preview": "npm run build && node src/server.js",
    "generate:rag-corpus": "node scripts/build-rag-corpus.mjs",
    "build": "npm run generate:rag-corpus && tsc",
    "test": "npm run generate:rag-corpus && vitest run",
    "typecheck": "npm run generate:rag-corpus && tsc --noEmit",
    "lint": "npm run generate:rag-corpus && eslint . --ext .ts,.tsx"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@types/node": "^22.15.19",
    "eslint": "^9.27.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.1",
    "vitest": "^3.1.3"
  }
}
